{
  "name": "pivotcli",
  "displayName": "PivotCLI",
  "description": "Sidebar panel to launch AI coding CLI tools — Gemini, Claude, Codex, OpenCode, KiloCode, and CommandCode — with multi-tab support",
  "version": "1.0.1",
  "publisher": "KamrulHasan",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamrulbds725/PivotCLI"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "images/icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pivotcli.newSession",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "pivotcli.openGemini",
        "title": "Gemini"
      },
      {
        "command": "pivotcli.openGeminiYolo",
        "title": "Gemini — YOLO"
      },
      {
        "command": "pivotcli.openClaude",
        "title": "Claude"
      },
      {
        "command": "pivotcli.openClaudeYolo",
        "title": "Claude — YOLO"
      },
      {
        "command": "pivotcli.openCodex",
        "title": "Codex"
      },
      {
        "command": "pivotcli.openCodexYolo",
        "title": "Codex — YOLO"
      },
      {
        "command": "pivotcli.openOpencode",
        "title": "OpenCode"
      },
      {
        "command": "pivotcli.openKilo",
        "title": "KiloCode"
      },
      {
        "command": "pivotcli.openCommandCode",
        "title": "CommandCode"
      },
      {
        "command": "pivotcli.openCommandCodeYolo",
        "title": "CommandCode — YOLO"
      },
      {
        "command": "pivotcli.showSessions",
        "title": "Session History",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "pivotcli.showSessions",
          "when": "view == pivotcli.panel",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pivotcli",
          "title": "PivotCLI",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "pivotcli": [
        {
          "type": "webview",
          "id": "pivotcli.panel",
          "name": "PivotCLI"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
